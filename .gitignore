# Ignore everything in raw/ (except .gitkeep to keep directory)
data/raw/*
!data/raw/.gitkeep # to keep directory in git

# Ignore everything in raw/ (except .gitkeep, and the sample subsets)
data/processed/*
!data/processed/.gitkeep
!data/processed/*_subset.parquet

# Ignore temporary environment file generated by Conda
condaenv.sst6rl2t*